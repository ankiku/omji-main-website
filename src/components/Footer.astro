---
const year = new Date().getFullYear();
---
<footer class="footer">
  <!-- Top ornamental rule is via CSS ::after -->

  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="navbar-logo" style="margin-bottom:0.5rem;">
          <div class="navbar-logo-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" width="18" height="18">
              <polygon points="3 9 12 2 21 9 21 22 3 22"/>
              <polyline points="9 22 9 14 15 14 15 22"/>
            </svg>
          </div>
          OMJI Construction
        </a>
        <p>Jaipur's trusted construction company. Premium home &amp; commercial building from foundation to finish — with quality materials, on-time delivery, and fixed pricing.</p>
        <!-- Heritage ornament -->
        <div style="display:flex;align-items:center;gap:8px;margin-top:1.2rem;opacity:0.5;">
          <div style="flex:1;height:1px;background:linear-gradient(90deg,rgba(183,138,60,0.4),transparent);"></div>
          <span style="color:var(--gold);font-size:0.65rem;">✦ ✦ ✦</span>
          <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(183,138,60,0.4));"></div>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <div class="footer-title">Company</div>
        <a href="/about" class="footer-link">About Us</a>
        <a href="/services" class="footer-link">Services</a>
        <a href="/projects" class="footer-link">Projects</a>
        <a href="/blog" class="footer-link">Blog</a>
        <a href="/contact" class="footer-link">Contact</a>
      </div>

      <!-- Services -->
      <div>
        <div class="footer-title">Services</div>
        <a href="/services" class="footer-link">Home Construction</a>
        <a href="/services" class="footer-link">Foundation Work</a>
        <a href="/services" class="footer-link">RCC Structure</a>
        <a href="/services" class="footer-link">Commercial Building</a>
        <a href="/services" class="footer-link">Renovation &amp; Repair</a>
      </div>

      <!-- Contact -->
      <div>
        <div class="footer-title">Contact</div>
        <a href="tel:+919929398279" class="footer-link">+91 99293 98279</a>
        <a href="mailto:contact@omjiconstruction.com" class="footer-link">contact@omjiconstruction.com</a>
        <span class="footer-link" style="cursor:default; line-height: 1.55;">Vaid ji ka chouraha, 282, Pratap Nagar Vistar, VKI Area, Murlipura, Jaipur</span>
        <a href="https://wa.me/919929398279" class="footer-link" style="color:var(--gold);font-weight:600;">WhatsApp Us →</a>
      </div>
    </div>

    <!-- Areas We Serve -->
    <div class="footer-areas">
      <div class="footer-title">Areas We Serve in Jaipur</div>
      <p class="footer-areas-list">Murlipura · Vishwakarma Industrial Area · Pratap Nagar Vistar · Mansarovar · Vaishali Nagar · Jagatpura · Malviya Nagar · Tonk Road · C-Scheme · Pratap Nagar · Sodala · Sitapura · Sanganer · Vidhyadhar Nagar · Jhotwara · Ajmer Road · Nirman Nagar · Bani Park</p>
    </div>

    <div class="footer-bottom">
      <span>© {year} OMJI Construction. All rights reserved. | Construction Company in Jaipur, Rajasthan</span>
      <span style="display:flex;align-items:center;gap:6px;">
        <span style="color:var(--gold);font-size:0.65rem;">✦</span>
        Built with pride in Jaipur
        <span style="color:var(--gold);font-size:0.65rem;">✦</span>
      </span>
    </div>
  </div>
</footer>
