---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---
<nav class="navbar" id="navbar">
  <div class="navbar-inner">
    <!-- Logo -->
    <a href="/" class="navbar-logo">
      <div class="navbar-logo-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" width="18" height="18">
          <polygon points="3 9 12 2 21 9 21 22 3 22"/>
          <polyline points="9 22 9 14 15 14 15 22"/>
        </svg>
      </div>
      OMJI Construction
    </a>

    <!-- Desktop Links -->
    <div class="navbar-links">
      {links.map(link => (
        <a
          href={link.href}
          class={`navbar-link ${currentPath === link.href ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA -->
    <a href="/contact" class="btn btn-primary btn-sm" style="display:none;" id="navCta">
      Free Consultation
    </a>

    <!-- Mobile Toggle -->
    <div class="navbar-toggle" id="navToggle" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  {links.map(link => (
    <a href={link.href}>{link.label}</a>
  ))}
  <a href="/contact" class="btn btn-primary" style="margin-top:1.5rem;">Free Consultation</a>
</div>

<style>
  @media (min-width: 901px) {
    #navCta { display: inline-flex !important; }
  }
</style>
