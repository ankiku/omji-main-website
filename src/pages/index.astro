  <!-- ═══════════════════════════════════
       PAGE SCRIPTS
       ═══════════════════════════════════ -->
  <script is:inline>
    // ── Hero Canvas: Architectural Grid Network ──
    (function () {
      const canvas = document.getElementById("heroCanvas");
      if (!canvas) return;
      const ctx = canvas.getContext("2d");
      let W,
        H,
        particles = [],
        mouse = { x: -1000, y: -1000 };

      function resize() {
        W = canvas.width = canvas.offsetWidth;
        H = canvas.height = canvas.offsetHeight;
      }
      resize();
      window.addEventListener("resize", resize);
      canvas.addEventListener("mousemove", (e) => {
        const r = canvas.getBoundingClientRect();
        mouse.x = e.clientX - r.left;
        mouse.y = e.clientY - r.top;
      });
      canvas.addEventListener("mouseleave", () => {
        mouse.x = -1000;
        mouse.y = -1000;
      });

      const count = Math.min(100, Math.floor((W * H) / 8000));
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          size: Math.random() * 1.5 + 0.5,
        });
      }

      function animate() {
        ctx.clearRect(0, 0, W, H);

        // Grid lines
        ctx.strokeStyle = "rgba(156,119,83,0.06)";
        ctx.lineWidth = 0.5;
        const gridSize = 60;
        for (let x = 0; x < W; x += gridSize) {
          ctx.beginPath();
          ctx.moveTo(x, 0);
          ctx.lineTo(x, H);
          ctx.stroke();
        }
        for (let y = 0; y < H; y += gridSize) {
          ctx.beginPath();
          ctx.moveTo(0, y);
          ctx.lineTo(W, y);
          ctx.stroke();
        }

        // Particles + connections
        particles.forEach((p) => {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0 || p.x > W) p.vx *= -1;
          if (p.y < 0 || p.y > H) p.vy *= -1;

          const dm = Math.hypot(mouse.x - p.x, mouse.y - p.y);
          if (dm < 150) {
            p.x += (p.x - mouse.x) * 0.01;
            p.y += (p.y - mouse.y) * 0.01;
          }

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(156,119,83,${dm < 150 ? 0.6 : 0.2})`;
          ctx.fill();
        });

        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            const dx = particles[i].x - particles[j].x;
            const dy = particles[i].y - particles[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 120) {
              ctx.beginPath();
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(particles[j].x, particles[j].y);
              ctx.strokeStyle = `rgba(156,119,83,${(1 - dist / 120) * 0.2})`;
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          }
        }

        function initHomeProjects() {
        const grid = document.getElementById('homeProjectsGrid');
        const noMsg = document.getElementById('no-home-projects-msg');
        if (!grid) return;
        
        const savedProjects = JSON.parse(localStorage.getItem('omji_projects') || '[]');
        if (savedProjects.length === 0) {
          grid.style.display = 'none';
          noMsg.style.display = 'block';
        } else {
          // Show max 6 on homepage
          grid.innerHTML = savedProjects.slice(0, 6).map((p, i) => {
            let photos = [];
            if (p.images) photos = p.images;
            else if (p.imageData) photos = [p.imageData];
            else {
              try { photos = JSON.parse(localStorage.getItem('omji_project_photos_' + p.id) || '[]'); } catch(e){}
            }
            const mainImg = photos.length > 0 ? photos[0] : null;
            
            return `
              <div class="project-card reveal antique-gold-border scalloped-arch on-card" onclick="openHomeModal(${p.id})">
                ${mainImg 
                  ? `<img src="${mainImg}" class="project-card-image" alt="${p.title}" loading="lazy" />` 
                  : `<div class="project-card-placeholder">🏗️</div>`}
                <div class="project-card-body">
                  <div class="project-card-type" style="text-transform:uppercase;font-size:0.75rem;color:var(--gold);letter-spacing:0.1em;margin-bottom:4px;">${p.category}</div>
                  <div class="project-card-name" style="font-family:var(--font-heading);font-size:1.2rem;font-weight:700;margin-bottom:12px;">${p.title}</div>
                  <div class="project-card-meta" style="display:flex;gap:8px;flex-wrap:wrap;">
                    ${p.area ? `<span class="project-meta-tag" style="font-size:0.8rem;background:var(--bg-glass);padding:4px 8px;border-radius:4px;border:1px solid var(--border);">📐 ${p.area}</span>` : ''}
                    ${p.year ? `<span class="project-meta-tag" style="font-size:0.8rem;background:var(--bg-glass);padding:4px 8px;border-radius:4px;border:1px solid var(--border);">📅 ${p.year}</span>` : ''}
                  </div>
                </div>
              </div>
            `;
          }).join('');
        }

        // Home Modal Logic
        const modal = document.getElementById('homeProjectModal');
        const modalClose = document.getElementById('homeModalClose');
        const modalTitle = document.getElementById('homeModalTitle');
        const modalMeta = document.getElementById('homeModalMeta');
        const modalDesc = document.getElementById('homeModalDesc');
        const modalGallery = document.getElementById('homeModalGallery');

        window.openHomeModal = function(id) {
          const p = savedProjects.find(x => x.id === id);
          if (!p) return;
          modalTitle.textContent = p.title;
          let metaHtml = `<span class="modal-meta-tag">${p.category}</span>`;
          if (p.area) metaHtml += `<span class="modal-meta-tag">📐 Area: ${p.area}</span>`;
          if (p.year) metaHtml += `<span class="modal-meta-tag">📅 Year: ${p.year}</span>`;
          modalMeta.innerHTML = metaHtml;
          modalDesc.textContent = p.description || 'No description provided.';
          
          let photos = [];
          if (p.images) photos = p.images;
          else if (p.imageData) photos = [p.imageData];
          else {
            try { photos = JSON.parse(localStorage.getItem('omji_project_photos_' + p.id) || '[]'); } catch(e){}
          }
          
          if (photos.length > 0) {
            modalGallery.innerHTML = photos.map(src => `<img src="${src}" class="gallery-img" loading="lazy" />`).join('');
          } else {
            modalGallery.innerHTML = `<div style="padding:2rem;text-align:center;color:var(--text-muted);background:var(--bg-elevated);border-radius:8px;border:1px dashed var(--border);grid-column:1/-1;">No photos uploaded for this project.</div>`;
          }
          
          modal.classList.add('open');
          document.body.style.overflow = 'hidden';
        };

        if(modalClose) {
          modalClose.addEventListener('click', () => {
            modal.classList.remove('open');
            document.body.style.overflow = '';
          });
          modal.addEventListener('click', (e) => {
            if (e.target === modal) {
              modal.classList.remove('open');
              document.body.style.overflow = '';
            }
          });
        }
      }
      initHomeProjects();
      
      requestAnimationFrame(animate);
      }
      animate();
    })();

    // ── Interactive Phases Tabs ──
    (function () {
      const tabs = document.querySelectorAll(".phase-tab-btn");
      const panes = document.querySelectorAll(".phase-pane");

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const idx = tab.getAttribute("data-phase-idx");

          tabs.forEach((t) => t.classList.remove("active"));
          panes.forEach((p) => p.classList.remove("active"));

          tab.classList.add("active");
          const targetPane = document.querySelector(
            `[data-phase-pane="${idx}"]`,
          );
          if (targetPane) targetPane.classList.add("active");
        });
      });
    })();

    // ── FAQ Accordion ──
    (function () {
      const faqButtons = document.querySelectorAll(".faq-question");
      faqButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const faqItem = btn.closest(".faq-item");
          const answer = faqItem.querySelector(".faq-answer");
          const isOpen = faqItem.classList.contains("open");

          // Close all others
          document.querySelectorAll(".faq-item.open").forEach((item) => {
            if (item !== faqItem) {
              item.classList.remove("open");
              item.querySelector(".faq-answer").style.maxHeight = "0";
            }
          });

          // Toggle current
          if (isOpen) {
            faqItem.classList.remove("open");
            answer.style.maxHeight = "0";
          } else {
            faqItem.classList.add("open");
            answer.style.maxHeight = answer.scrollHeight + "px";
          }
        });
      });
    })();
  </script>
</BaseLayout>
