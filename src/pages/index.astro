    >
    </div>
    <div
      style="position:absolute;inset:0;background-image:url(&quot;data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%238A6A44' fill-opacity='0.03'%3E%3Cpath d='M40 0 L80 40 L40 80 L0 40 Z'/%3E%3C/g%3E%3C/svg%3E&quot;);pointer-events:none;"
    >
    </div>
    <div class="jali-pattern-overlay" style="opacity: 0.15; z-index: 1;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-header reveal">
        <div class="section-tag">Our Biggest Promise</div>
        <h2 class="display-md">
          You See Everything, <span class="gold-text">Every Single Day</span>
        </h2>
        <p class="section-subtitle">
          Every OMJI project gets its own live digital dashboard — the <strong
            >OMJI Site Register</strong
          >. Real-time photos, phase tracking, engineer checklists, material
          test records, and <strong>live CCTV camera access</strong> — all in one
          place, shared with you daily.
        </p>
      </div>

      <!-- Main feature panel -->
      <div
        class="reveal antique-gold-border"
        style="background:linear-gradient(145deg,var(--bg-card),var(--bg-elevated));border-radius:var(--radius-xl);overflow:hidden;"
      >
        <div
          style="height:3px;background:linear-gradient(90deg,var(--maroon),var(--gold),var(--gold-light));"
        >
        </div>
        <div
          class="dashboard-layout"
          style="padding:clamp(24px,5vw,52px);display:grid;grid-template-columns:repeat(auto-fit, minmax(min(100%, 400px), 1fr));gap:clamp(2rem, 5vw, 4rem);align-items:center;"
        >
          <!-- Left content -->
          <div>
            <div
              style="display:inline-flex;align-items:center;gap:8px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);border-radius:var(--radius-full);padding:6px 18px;margin-bottom:1.5rem;"
            >
              <span
                style="width:8px;height:8px;border-radius:50%;background:#22c55e;box-shadow:0 0 8px rgba(34,197,94,0.5);"
