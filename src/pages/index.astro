        <img src="/images/phase-04.png" alt="" loading="eager" fetchpriority="low" decoding="async" />
      </div>
      <!-- Tiles 2-8: lazy-load for performance -->
      <div class="hero-photo-tile hero-photo-tile--2">
        <img src="/images/phase-06.png" alt="" loading="lazy" decoding="async" />
      </div>
      <div class="hero-photo-tile hero-photo-tile--3">
