---

<BaseLayout faqSchema={faqs} preloadImage={optimizedHero.src}>
  <!-- ═══════════════════════════════════
       HERO SECTION
       ═══════════════════════════════════ -->
  <section class="hero" id="hero">
    <canvas class="hero-canvas" id="heroCanvas"></canvas>

    <!-- ░░░ VINTAGE CSS MESH BACKGROUND (Fast Loading) ░░░ -->
    <div class="hero-photo-bg fast-loading-bg" aria-hidden="true">
      <div class="mesh-gradient"></div>
      
      <!-- SVG Fort & Jharokha Architectural Design (Pure Code, No Images) -->
      <div class="fort-arch-bg">
        <!-- Left Jharokha -->
        <svg class="jharokha-svg left-jharokha" viewBox="0 0 200 300" xmlns="http://www.w3.org/2000/svg">
           <g stroke="var(--gold)" stroke-width="3" fill="rgba(183, 138, 60, 0.05)" opacity="0.6">
              <!-- Dome -->
              <path d="M 100 10 C 120 10, 140 40, 140 60 L 60 60 C 60 40, 80 10, 100 10 Z"/>
              <line x1="100" y1="10" x2="100" y2="0" />
              <circle cx="100" cy="5" r="3" />
              <!-- Rajput Ogee Arch -->
              <path d="M 40 300 L 40 120 C 40 80, 60 70, 80 60 C 90 55, 100 45, 100 45 C 100 45, 110 55, 120 60 C 140 70, 160 80, 160 120 L 160 300" stroke-width="4"/>
              <path d="M 50 300 L 50 120 C 50 90, 70 80, 85 70 C 95 62, 100 55, 100 55 C 100 55, 105 62, 115 70 C 130 80, 150 90, 150 120 L 150 300" />
              <!-- Balcony Base -->
              <path d="M 20 280 L 180 280 L 170 300 L 30 300 Z" />
              <!-- Pillars -->
              <line x1="45" y1="280" x2="45" y2="115" />
              <line x1="155" y1="280" x2="155" y2="115" />
              <line x1="35" y1="280" x2="35" y2="135" />
              <line x1="165" y1="280" x2="165" y2="135" />
           </g>
        </svg>

        <!-- Right Jharokha -->
        <svg class="jharokha-svg right-jharokha" viewBox="0 0 200 300" xmlns="http://www.w3.org/2000/svg">
           <g stroke="var(--gold)" stroke-width="3" fill="rgba(183, 138, 60, 0.05)" opacity="0.6">
              <path d="M 100 10 C 120 10, 140 40, 140 60 L 60 60 C 60 40, 80 10, 100 10 Z"/>
              <line x1="100" y1="10" x2="100" y2="0" />
              <circle cx="100" cy="5" r="3" />
              <path d="M 40 300 L 40 120 C 40 80, 60 70, 80 60 C 90 55, 100 45, 100 45 C 100 45, 110 55, 120 60 C 140 70, 160 80, 160 120 L 160 300" stroke-width="4"/>
              <path d="M 50 300 L 50 120 C 50 90, 70 80, 85 70 C 95 62, 100 55, 100 55 C 100 55, 105 62, 115 70 C 130 80, 150 90, 150 120 L 150 300" />
              <path d="M 20 280 L 180 280 L 170 300 L 30 300 Z" />
              <line x1="45" y1="280" x2="45" y2="115" />
              <line x1="155" y1="280" x2="155" y2="115" />
              <line x1="35" y1="280" x2="35" y2="135" />
              <line x1="165" y1="280" x2="165" y2="135" />
           </g>
        </svg>
        
        <!-- Fort Battlements Background Line -->
        <svg class="fort-wall-svg" viewBox="0 0 1000 200" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M 0 200 L 0 100 
                   L 20 100 L 20 120 L 50 120 L 50 100 
                   L 80 100 L 80 120 L 110 120 L 110 100 
                   L 140 100 L 140 120 L 170 120 L 170 100
                   L 200 100 L 200 120 L 230 120 L 230 100
                   L 260 100 L 260 120 L 290 120 L 290 100
                   L 320 100 L 320 120 L 350 120 L 350 100
                   L 380 100 L 380 120 L 410 120 L 410 100
                   L 440 100 L 440 120 L 470 120 L 470 100
                   L 500 100 L 500 120 L 530 120 L 530 100
                   L 560 100 L 560 120 L 590 120 L 590 100
                   L 620 100 L 620 120 L 650 120 L 650 100
                   L 680 100 L 680 120 L 710 120 L 710 100
                   L 740 100 L 740 120 L 770 120 L 770 100
                   L 800 100 L 800 120 L 830 120 L 830 100
                   L 860 100 L 860 120 L 890 120 L 890 100
                   L 920 100 L 920 120 L 950 120 L 950 100
                   L 980 100 L 980 120 L 1000 120 L 1000 200 Z" 
                fill="rgba(183, 138, 60, 0.05)" stroke="var(--gold)" stroke-width="3" opacity="0.4"/>
        </svg>
      </div>
    </div>

    <!-- Vintage overlay layers: sandstone wash + vignette -->
    <div class="hero-vintage-wash" aria-hidden="true"></div>
    <div class="hero-vignette" aria-hidden="true"></div>
    <div class="hero-overlay"></div>
    <div class="jali-pattern-overlay" style="opacity: 0.35; z-index: 1;"></div>



    <div class="hero-content pillar-flanks" style="padding: 0 40px;">
      <!-- Heritage label badge -->
      <div class="hero-label">
        <span class="story-phase-dot"></span>
        Jaipur's Trusted Construction Company
