---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

const slug = Astro.url.searchParams.get('id');

let post = null;
try {
  const DATA_FILE = path.join(process.cwd(), 'data', 'blogs.json');
  if (fs.existsSync(DATA_FILE)) {
    const savedBlogs = JSON.parse(fs.readFileSync(DATA_FILE, 'utf-8'));
    const now = new Date().getTime();
    const found = savedBlogs.find(p => p.slug === slug);
    if (found && new Date(found.publishDate).getTime() <= now) {
      post = found;
    }
  }
} catch(e) {}
---
<BaseLayout 
  title={post ? `${post.title} — OMJI Construction` : "Post Not Found"} 
  description={post ? post.excerpt : "Blog post not found."}
>
  {post ? (
    <div id="blog-content-wrapper">
      <section class="page-hero">
        <div class="container">
          <div class="breadcrumb"><a href="/">Home</a><span>/</span><a href="/blog">Blog</a><span>/</span><span style="color:var(--bronze)">{post.title.length > 30 ? post.title.substring(0, 30) + '...' : post.title}</span></div>
          <div class="section-tag">{post.cat}</div>
          <h1 class="page-hero-title" style="max-width: 900px;">{post.title}</h1>
          <div style="display:flex;gap:1.5rem;align-items:center;margin-top:1.5rem;color:var(--text-muted);font-size:0.9rem;">
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="width:32px;height:32px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;">OM</div>
              <span style="color:var(--text-primary);font-weight:600;">{post.author || 'Admin'}</span>
            </div>
            <span>{new Date(post.publishDate).toLocaleDateString('en-US', {month: 'long', day: 'numeric', year: 'numeric'})}</span>
            <span>{post.readTime || '5 min read'}</span>
          </div>
        </div>
      </section>

      <section class="section" style="padding-top:2rem;">
        <div class="container" style="max-width: 800px; margin: 0 auto;">
          {post.image && <img src={post.image} alt={post.title} style="width:100%; height:450px; object-fit:cover; border-radius:var(--radius-lg); margin-bottom:3rem;" />}
          <div class="article-body" set:html={post.content}></div>
        </div>
      </section>
    </div>
  ) : (
    <div id="not-found" style="text-align:center; padding: 10rem 2rem;">
      <h1 class="display-lg">Post Not Found</h1>
      <p class="body-lg" style="margin: 1rem 0 2rem;">This post may have been removed or is not yet published.</p>
      <a href="/blog" class="btn btn-primary">Back to Blog</a>
    </div>
  )}
</BaseLayout>
