      <!-- SETTINGS TAB -->
      <div class="tab-content" id="tab-settings">
        <div class="admin-panel">
          <div class="admin-panel-title">Site Settings</div>
          
          <div id="ga-display-section" style="display:none; padding:15px; border:1px solid var(--border); border-radius:8px; margin-bottom:15px; background:var(--bg-elevated);">
            <div style="font-weight:600; margin-bottom:5px;">Google Analytics Status: <span style="color:var(--success);">Active</span></div>
            <div style="color:var(--text-muted); font-size:0.9rem; margin-bottom:10px;">Current ID: <strong id="current-ga-id" style="color:var(--text-primary);"></strong></div>
            <div style="display:flex; gap:10px;">
              <button class="btn btn-ghost" id="edit-ga-btn" style="padding:6px 12px; font-size:0.8rem;">Edit</button>
              <button class="btn btn-ghost" id="delete-ga-btn" style="padding:6px 12px; font-size:0.8rem; color:#ef4444; border-color:#ef4444;">Delete</button>
            </div>
          </div>
          
          <div id="ga-edit-section">
            <div class="form-group">
              <label class="form-label" for="settings-ga">Google Analytics Measurement ID</label>
              <input type="text" class="form-input" id="settings-ga" placeholder="e.g. G-XXXXXXXXXX">
              <div style="font-size:0.8rem;color:var(--text-muted);margin-top:5px;">This will automatically inject the Google Analytics tracking script into the head of all pages.</div>
            </div>
            <div style="display:flex; gap:10px;">
              <button class="btn btn-primary" id="save-settings-btn">Save Settings</button>
              <button class="btn btn-ghost" id="cancel-ga-edit-btn" style="display:none;">Cancel</button>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>

<script is:inline>
  let localProjects = window.initialProjects;
  let localContacts = window.initialContacts;
  let localBlogs = window.initialBlogs;
  let envGeminiKey = window.envGeminiKey;

  // Auth Guard Double Check
  if (sessionStorage.getItem('omji_admin_auth') !== 'true') {
    window.location.href = '/admin';
  }

  // Fetch real data from APIs
  async function loadData() {
    try {
      const pRes = await fetch('/api/projects');
      if (pRes.ok) localProjects = await pRes.json();
    } catch(e) {}
    try {
      const cRes = await fetch('/api/contacts');
      if (cRes.ok) localContacts = await cRes.json();
    } catch(e) {}
    try {
      const bRes = await fetch('/api/blogs');
      if (bRes.ok) localBlogs = await bRes.json();
    } catch(e) {}
    try {
      const sRes = await fetch('/api/settings');
      if (sRes.ok) {
        const settings = await sRes.json();
        updateGAUIState(settings.googleAnalyticsId);
      }
    } catch(e) {}
    
    // Re-render active tabs once data loads
    updateOverviewStats();
    if (document.getElementById('tab-manage').classList.contains('active')) renderManageGrid();
    if (document.getElementById('tab-contacts').classList.contains('active')) renderContactsGrid();
  }
  loadData();

  // Settings UI State Logic
  function updateGAUIState(gaId) {
    if (gaId && gaId.trim() !== '') {
      document.getElementById('ga-display-section').style.display = 'block';
      document.getElementById('ga-edit-section').style.display = 'none';
      document.getElementById('current-ga-id').innerText = gaId;
      document.getElementById('settings-ga').value = gaId;
    } else {
      document.getElementById('ga-display-section').style.display = 'none';
      document.getElementById('ga-edit-section').style.display = 'block';
      document.getElementById('cancel-ga-edit-btn').style.display = 'none';
      document.getElementById('settings-ga').value = '';
    }
  }

  const editGaBtn = document.getElementById('edit-ga-btn');
  const cancelGaBtn = document.getElementById('cancel-ga-edit-btn');
  const deleteGaBtn = document.getElementById('delete-ga-btn');

  if (editGaBtn) {
    editGaBtn.addEventListener('click', () => {
      document.getElementById('ga-display-section').style.display = 'none';
      document.getElementById('ga-edit-section').style.display = 'block';
      document.getElementById('cancel-ga-edit-btn').style.display = 'block';
    });
  }

  if (cancelGaBtn) {
    cancelGaBtn.addEventListener('click', () => {
      const currentVal = document.getElementById('current-ga-id').innerText;
      updateGAUIState(currentVal);
    });
  }

  if (deleteGaBtn) {
    deleteGaBtn.addEventListener('click', async () => {
      if(confirm('Are you sure you want to remove the Google Analytics ID?')) {
        deleteGaBtn.innerText = 'Deleting...';
        try {
          const res = await fetch('/api/settings', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ googleAnalyticsId: null })
          });
          if (res.ok) {
            updateGAUIState(null);
          } else {
            alert('Failed to delete.');
          }
        } catch (err) {
          alert('Error: ' + err.message);
        }
        deleteGaBtn.innerText = 'Delete';
      }
    });
  }

  // Settings Save Logic
  const saveSettingsBtn = document.getElementById('save-settings-btn');
  if (saveSettingsBtn) {
    saveSettingsBtn.addEventListener('click', async () => {
      const gaId = document.getElementById('settings-ga').value.trim();
      
      saveSettingsBtn.innerText = 'Saving...';
      try {
        const res = await fetch('/api/settings', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ googleAnalyticsId: gaId || null })
        });
        if (res.ok) {
          saveSettingsBtn.innerText = 'Saved!';
          setTimeout(() => {
            saveSettingsBtn.innerText = 'Save Settings';
            updateGAUIState(gaId);
          }, 1000);
        } else {
          alert('Failed to save settings.');
          saveSettingsBtn.innerText = 'Save Settings';
        }
      } catch (err) {
        alert('Error saving settings: ' + err.message);
        saveSettingsBtn.innerText = 'Save Settings';
      }
    });
  }

  // Sidebar Tabs Switching
  const tabs = document.querySelectorAll('.sidebar-link[data-tab]');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Close sidebar on mobile
      const s = document.querySelector('.admin-sidebar');
      if (s) s.classList.remove('open');
      tabs.forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      
      tab.classList.add('active');
      const tabName = tab.dataset.tab;
      document.getElementById('tab-' + tabName).classList.add('active');
      document.getElementById('page-title').textContent = tab.textContent.trim();
      
      if (tabName === 'manage') renderManageGrid();
      if (tabName === 'contacts') renderContactsGrid();
      updateOverviewStats();
    });
  });

  // Log Out
  document.getElementById('logout-btn').addEventListener('click', () => {
    sessionStorage.removeItem('omji_admin_auth');
    window.location.href = '/admin';
  });

  // API Data Functions (Replacing LocalStorage)
  function getProjects() { return localProjects; }
  function getContacts() { return localContacts; }
  function getBlogs() { return localBlogs; }

  // Toasts
  let toastTimer;
  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = `toast toast-${type} show`;
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
  }

  // Drag and Drop & Multiple Image base64 Upload handlers
  let currentImages = []; // Array to store multiple base64 strings
  const fileInput = document.getElementById('file-input');
  const dropZone = document.getElementById('drop-zone');
  const dropContent = document.getElementById('drop-zone-content');
  const previewCont = document.getElementById('preview-container');
  const previewGrid = document.getElementById('preview-grid');

  function handleFiles(files) {
    if (!files || files.length === 0) return;
    
    let added = 0;
    Array.from(files).forEach(file => {
      if (!file.type.startsWith('image/')) {
        showToast(`Skipped ${file.name} - not an image.`, 'error');
        return;
      }
      if (file.size > 8 * 1024 * 1024) {
        showToast(`Skipped ${file.name} - exceeds 8MB.`, 'error');
        return;
      }
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          const canvas = document.createElement('canvas');
          let width = img.width;
          let height = img.height;
          const MAX_SIZE = 1920; // Max dimension
          
          if (width > height && width > MAX_SIZE) {
            height *= MAX_SIZE / width;
            width = MAX_SIZE;
          } else if (height > MAX_SIZE) {
            width *= MAX_SIZE / height;
            height = MAX_SIZE;
          }
          
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, width, height);
          
          // Compress and convert to WEBP
          const webpDataUrl = canvas.toDataURL('image/webp', 0.8);
          
          currentImages.push(webpDataUrl);
          renderPreviews();
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
      added++;
    });
    
    if (added > 0) {
      dropContent.style.display = 'none';
      previewCont.style.display = 'block';
    }
  }

