---
export const prerender = false;
// Admin dashboard page — blocked from crawler indexing
const initialProjects = [];
const initialContacts = [];
const initialBlogs = [];
import { getFinances, getMaterials } from '../../lib/data-store.js';
const initialFinances = getFinances();
const initialMaterials = getMaterials();
import '../../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard | Omji Construction</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { background: var(--bg-elevated) !important; min-height: 100vh; font-family: var(--font-body); margin: 0; }
    
    /* Layout */
    .admin-layout { display: flex; min-height: 100vh; }
    .admin-sidebar { 
      width: 260px; 
      background: var(--bg-card); 
      border-right: 1px solid var(--border); 
      display: flex; 
      flex-direction: column; 
      position: fixed; 
      top: 0; bottom: 0; left: 0;
      z-index: 50;
    }
    .admin-main { flex: 1; margin-left: 260px; display: flex; flex-direction: column; }
    
    /* Sidebar */
    .sidebar-logo { padding: 24px; border-bottom: 1px solid var(--border); }
    .sidebar-nav { padding: 20px 12px; flex: 1; display: flex; flex-direction: column; gap: 4px; }
    .sidebar-link { 
      display: flex; align-items: center; padding: 12px 16px; 
      border-radius: var(--radius-sm); border: none; background: transparent; 
      color: var(--text-secondary); font-size: 0.9rem; font-weight: 500; cursor: pointer;
      text-decoration: none; transition: all 0.2s;
    }
    .sidebar-link:hover { background: var(--bg-glass); color: var(--bronze); }
    .sidebar-link.active { background: var(--gold-pale); color: var(--bronze); font-weight: 600; border-left: 3px solid var(--gold); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }
    .sidebar-footer { padding: 20px; border-top: 1px solid var(--border); }
    .sidebar-logout { 
      display: flex; align-items: center; width: 100%; padding: 10px; 
      background: transparent; border: 1px solid var(--border); border-radius: var(--radius-sm);
      color: var(--text-muted); cursor: pointer; font-size: 0.85rem; transition: all 0.2s;
    }
    .sidebar-logout:hover { background: rgba(220,60,60,0.1); color: #c44; border-color: rgba(220,60,60,0.3); }

    /* Topbar */
    .admin-topbar { 
      height: 72px; padding: 0 32px; background: var(--bg-card); 
      border-bottom: 1px solid var(--border); display: flex; 
      align-items: center; justify-content: space-between; 
    }
    .admin-topbar h1 { font-family: var(--font-display); font-size: 1.4rem; color: var(--text-primary); margin: 0; }
    .admin-badge { background: var(--gold-pale); color: var(--bronze); padding: 4px 12px; border-radius: 99px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em; border: 1px solid var(--border-ornament); }

    /* Content Area */
    .admin-content { padding: 32px; max-width: 1200px; }
    .tab-content { display: none; animation: fadeIn 0.3s ease; }
    .tab-content.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

    /* Panels & Cards */
    .admin-panel { background: #FFFFFF; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; box-shadow: var(--shadow-sm); margin-bottom: 24px; }
    .admin-panel-title { display: flex; align-items: center; gap: 10px; font-family: var(--font-display); font-size: 1.15rem; font-weight: 700; color: var(--text-primary); margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid var(--border-light); }
    
    .stat-mini { background: linear-gradient(145deg, #FFFFFF, var(--bg-elevated)); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; box-shadow: 0 4px 15px rgba(92,50,10,0.05); transition: all 0.3s ease; position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: center; }
    .stat-mini::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--gold), var(--bronze)); opacity: 0; transition: opacity 0.3s; }
    .stat-mini:hover { transform: translateY(-5px); box-shadow: 0 12px 25px rgba(92,50,10,0.12); border-color: var(--gold-pale); }
    .stat-mini:hover::before { opacity: 1; }
    .stat-mini-icon { position: absolute; right: 20px; top: 24px; color: var(--gold-pale); opacity: 0.5; width: 48px; height: 48px; pointer-events: none; }
    .stat-mini-num { font-family: var(--font-display); font-size: 2.8rem; font-weight: 800; color: var(--bronze); line-height: 1; margin-bottom: 6px; z-index: 1; }
    .stat-mini-lbl { font-size: 0.9rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; z-index: 1; }

    /* Upload & Forms */
    .upload-zone { border: 2px dashed var(--border-ornament); border-radius: var(--radius-md); padding: 40px 20px; text-align: center; background: var(--bg-glass); cursor: pointer; transition: all 0.2s; margin-bottom: 24px; }
    .upload-zone:hover, .upload-zone.over { background: var(--gold-pale); border-color: var(--gold); }
    
    .admin-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .admin-field.full { grid-column: 1 / -1; }
    .admin-field label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em; }
    .admin-field input, .admin-field select, .admin-field textarea { width: 100%; padding: 12px 14px; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 0.95rem; color: var(--text-primary); transition: all 0.2s; outline: none; box-sizing: border-box; }
    .admin-field select { cursor: pointer; appearance: auto; }
    .admin-field select option { background-color: #F5ECD8; color: #1A1208; }
    .admin-field input:focus, .admin-field select:focus, .admin-field textarea:focus { border-color: var(--gold); background: #FFFFFF; box-shadow: 0 0 0 3px rgba(154,111,40,0.1); }
    .admin-field textarea { resize: vertical; min-height: 100px; }

    /* Manage Projects Grid */
    .projects-admin-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
    .proj-admin-card { background: #FFFFFF; border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; }
    .proj-admin-img-placeholder { background: var(--bg-elevated); font-size: 2rem; color: var(--text-muted); display: flex; align-items: center; justify-content: center; height: 200px; }
    .proj-admin-info { padding: 16px; flex: 1; display: flex; flex-direction: column; }
    .proj-admin-name { font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .proj-admin-cat { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.05em; }
    .btn-delete { margin-top: auto; padding: 8px; width: 100%; background: rgba(220,60,60,0.05); color: #c44; border: 1px solid rgba(220,60,60,0.2); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 0.85rem; }
    .btn-delete:hover { background: rgba(220,60,60,0.1); border-color: rgba(220,60,60,0.4); }

    /* Empty State */
    .empty-state { text-align: center; padding: 60px 20px; color: var(--text-muted); }
    .empty-state-icon { font-size: 3rem; margin-bottom: 16px; opacity: 0.6; }

    /* Toasts */
    .toast {
      position: fixed; bottom: 2rem; right: 2rem; z-index: 9999;
      padding: 14px 22px; border-radius: var(--radius-md);
      font-size: 0.88rem; font-weight: 600;
      transform: translateY(80px); opacity: 0;
      transition: transform 0.4s, opacity 0.4s;
      pointer-events: none;
    }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast-success { background: rgba(176,141,87,0.15); border: 1px solid rgba(176,141,87,0.4); color: var(--bronze-hover); }
    .toast-error { background: rgba(220,60,60,0.12); border: 1px solid rgba(220,60,60,0.3); color: #c44; }

    .admin-responsive-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 24px; }
    @media (max-width: 768px) {
      .admin-responsive-grid { grid-template-columns: 1fr !important; }
      .admin-sidebar { transform: translateX(-100%); transition: transform 0.3s; }
      .admin-sidebar.open { transform: translateX(0); }
      .admin-main { margin-left: 0; }
      .admin-topbar { padding: 0 16px; }
      .mobile-toggle { display: block !important; }
      .admin-content { padding: 16px; }
      .projects-admin-grid, .admin-form-grid { grid-template-columns: 1fr; }
      .stat-mini { margin-bottom: 10px; }
    }
    .mobile-toggle { display: none; background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-primary); margin-right: 15px; }
  
    .mobile-close-btn { display: none; background: transparent; border: none; font-size: 2rem; color: var(--text-primary); cursor: pointer; line-height: 1; margin-top:-5px; }
    @media (max-width: 768px) {
      .mobile-close-btn { display: block; }
    }
</style>

</head>
<body>

<div class="toast" id="toast"></div>

<script is:inline define:vars={{ initialProjects, initialContacts, initialBlogs, initialFinances, initialMaterials, envGeminiKey: import.meta.env.PUBLIC_GEMINI_API_KEY || '' }}>
  window.initialFinances = initialFinances;
  window.initialMaterials = initialMaterials;
  window.initialProjects = initialProjects;
  window.initialContacts = initialContacts;
  window.initialBlogs = initialBlogs;
  window.envGeminiKey = envGeminiKey;
  if (sessionStorage.getItem('omji_admin_auth') !== 'true') {
    window.location.href = '/admin';
  }
</script>

<div class="admin-layout">
  <!-- SIDEBAR -->
  <aside class="admin-sidebar">
    <div class="sidebar-logo">
      <div style="display:flex;align-items:center;gap:10px;justify-content:space-between;width:100%;">
        <div style="display:flex;align-items:center;gap:10px;">
          <svg width="28" height="28" viewBox="0 0 36 36" fill="none">
            <polygon points="18,2 34,30 2,30" stroke="#B08D57" stroke-width="2" fill="none"/>
            <polygon points="18,10 27,27 9,27" stroke="#B08D57" stroke-width="1" fill="rgba(176,141,87,0.12)"/>
          </svg>
          <div>
            <div style="font-family:var(--font-display);font-size:1rem;font-weight:900;letter-spacing:0.1em;color:var(--bronze);line-height:1;">OMJI</div>
            <div style="font-size:0.48rem;letter-spacing:0.2em;color:var(--text-muted);text-transform:uppercase;">Admin Panel</div>
          </div>
        </div>
        <button class="mobile-close-btn" id="mobile-close-btn">×</button>
      </div>
    </div>

    <nav class="sidebar-nav">
      <button class="sidebar-link active" data-tab="overview">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;vertical-align:middle;"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Overview
      </button>
      <button class="sidebar-link" data-tab="upload">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;vertical-align:middle;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
        Upload Project
      </button>
      <button class="sidebar-link" data-tab="contacts">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;vertical-align:middle;"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        Contact Requests
      </button>
      <button class="sidebar-link" data-tab="manage">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;vertical-align:middle;"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Manage Projects
      </button>
      <button class="sidebar-link" data-tab="ai-blog">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;vertical-align:middle;"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"></path></svg>
        AI Blog Autopilot
      </button>
      <button class="sidebar-link" data-tab="manage-blogs">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;vertical-align:middle;"><path d="M4 6h16M4 12h16M4 18h12"/></svg>
        Manage Blogs
      </button>
      <button class="sidebar-link" data-tab="tracker">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;vertical-align:middle;"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        Site Tracker
      </button>
      <button class="sidebar-link" data-tab="settings">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;vertical-align:middle;"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
        Site Settings
      </button>
      <a class="sidebar-link" href="/projects" style="margin-top:auto; display:block; padding:11px 20px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;vertical-align:middle;"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
        View Website
      </a>
    </nav>

    <div class="sidebar-footer">
      <div id="admin-user-info" style="font-size:0.8rem;color:var(--text-muted);margin-bottom:10px;">Logged in as <strong style="color:var(--bronze);">admin</strong></div>
      <button class="sidebar-logout" id="logout-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;vertical-align:middle;"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
        Log Out
      </button>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="admin-main">
    <div class="admin-topbar">
      <div style="display:flex; align-items:center;">
        <button class="mobile-toggle" id="mobile-toggle">☰</button>
        <h1 id="page-title">Overview</h1>
      </div>
      <span class="admin-badge">✦ Admin</span>
    </div>

    <div class="admin-content">

      <!-- OVERVIEW TAB -->
      <div class="tab-content active" id="tab-overview">
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:20px; margin-bottom:32px;">
          <!-- Card 1 -->
          <div class="stat-mini">
            <svg class="stat-mini-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            <div class="stat-mini-num" id="total-count">0</div>
            <div class="stat-mini-lbl">Live Projects</div>
          </div>
          <!-- Card 2 -->
          <div class="stat-mini">
            <svg class="stat-mini-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            <div class="stat-mini-num" id="overview-contacts-count">0</div>
            <div class="stat-mini-lbl">Contact Inquiries</div>
          </div>
          <!-- Card 3 -->
          <div class="stat-mini">
            <svg class="stat-mini-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"></path></svg>
            <div class="stat-mini-num" id="overview-blogs-count">0</div>
            <div class="stat-mini-lbl">AI Generated Blogs</div>
          </div>
          <!-- Card 4 -->
          <div class="stat-mini" style="background: linear-gradient(145deg, #F9F2E7, var(--bg-elevated));">
            <svg class="stat-mini-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
            <div class="stat-mini-num" style="color:var(--success); font-size:2rem; margin-top:8px;">Online</div>
            <div class="stat-mini-lbl">API & System Status</div>
          </div>
        </div>

        <div class="admin-responsive-grid">
          <div class="admin-panel" style="margin-bottom:0;">
            <div class="admin-panel-title">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B08D57" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Dashboard Instructions
            </div>
            <div style="display:flex; flex-direction:column; gap:16px;">
              <p style="font-size:0.95rem; line-height:1.7; color:var(--text-body);">Welcome to the OMJI Construction Admin Portal. From here, you can seamlessly manage all aspects of your digital presence.</p>
              <ul style="font-size:0.9rem; line-height:1.8; color:var(--text-muted); padding-left:20px;">
                <li><strong>Upload Project:</strong> Add new high-resolution webp images to your portfolio grid.</li>
                <li><strong>Manage Projects:</strong> Remove or organize existing projects.</li>
                <li><strong>Contact Requests:</strong> View real-time submissions from your website's contact form.</li>
                <li><strong>AI Blog Autopilot:</strong> Automatically generate SEO-optimized construction articles using Google Gemini.</li>
              </ul>
            </div>
          </div>
          
          <div class="admin-panel" style="margin-bottom:0; background:var(--bg-elevated);">
            <div class="admin-panel-title">Quick Actions</div>
            <div style="display:flex; flex-direction:column; gap:12px;">
              <button class="btn btn-primary" style="width:100%; text-align:center;" onclick="document.querySelector('[data-tab=\'upload\']').click()">+ Upload Project</button>
              <button class="btn btn-ghost" style="width:100%; text-align:center; background:#fff;" onclick="document.querySelector('[data-tab=\'ai-blog\']').click()">Generate AI Blog</button>
              <button class="btn btn-ghost" style="width:100%; text-align:center; background:#fff;" onclick="document.querySelector('[data-tab=\'contacts\']').click()">View Inquiries</button>
            </div>
          </div>
        </div>
      </div>

      <!-- CONTACTS TAB -->
      <div class="tab-content" id="tab-contacts">
        <div class="admin-panel">
          <div class="admin-panel-title" style="justify-content:space-between;">
            <span>Contact Form Submissions</span>
            <button class="btn btn-ghost btn-sm" id="clear-contacts-btn" style="color:#c44; border-color:rgba(220,60,60,0.3);">Clear All</button>
          </div>
          <div style="display:flex;flex-direction:column;gap:16px;" id="contacts-grid"></div>
          <div class="empty-state" id="contacts-empty-state">
            <div class="empty-state-icon">📥</div>
            <p>No contact requests yet.</p>
          </div>
        </div>
      </div>

      <!-- UPLOAD TAB -->
      <div class="tab-content" id="tab-upload">
        <div class="admin-panel">
          <div class="admin-panel-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B08D57" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
            Upload New Project
          </div>

          <div class="upload-zone drag-zone" id="drop-zone" onclick="document.getElementById('file-input').click()">
            <input type="file" id="file-input" style="display:none;" accept="image/*" multiple />
            <div id="drop-zone-content">
              <div style="font-size:3rem; margin-bottom:0.75rem;">🖼️</div>
              <div style="font-size:0.95rem; font-weight:600; margin-bottom:0.4rem;">Click to upload or drag & drop (Multiple Allowed)</div>
              <div style="font-size:0.8rem; color:var(--text-muted);">PNG, JPG, WEBP — Max 5MB recommended</div>
            </div>
            <div id="preview-container" style="display:none; width: 100%;">
