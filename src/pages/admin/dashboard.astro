  aiStartBtn.addEventListener('click', async () => {
    const key = geminiKeyInput.value.trim() || envGeminiKey;
    if (!key) {
      showToast('Please enter your Gemini API Key.', 'error');
      return;
    }

    aiStartBtn.disabled = true;
    aiProgressContainer.style.display = 'block';
    aiLog.innerHTML = '';
    
    logAi(`Starting AI Autopilot. Using API Key ending in: ...${key.slice(-4)}`);
    
    const totalPosts = parseInt(document.getElementById('ai-total-blogs').value) || 30;
    const postsPerDay = parseInt(document.getElementById('ai-blogs-per-day').value) || 1;
    
    document.getElementById('ai-progress-text').textContent = `0 / ${totalPosts}`;
    
    const topics = [
      'RCC Construction techniques', 'Modern Brickwork patterns', 'High quality steel Fe 500D',
      'Construction interior design', 'House foundation planning', 'Cement grading M20 M25 M30',
      'Civil engineering safety', 'Jaipur building guidelines', 'Waterproofing solutions',
      'Cost estimation in construction', 'Architecture trends 2025', 'Choosing right aggregates'
    ];
    const emojis = ['🏗️', '🧱', '🧪', '📋', '🛡️', '💰', '🏠', '✨', '🛠️', '📐'];

    let consecutiveFailures = 0;

    for (let i = 1; i <= totalPosts; i++) {
      const dayOffset = Math.floor((i - 1) / postsPerDay);
      const publishDate = new Date();
      publishDate.setDate(publishDate.getDate() + dayOffset);
      
      const randomTopic = topics[Math.floor(Math.random() * topics.length)];
      const randomEmoji = emojis[Math.floor(Math.random() * emojis.length)];
      
      logAi(`[${i}/${totalPosts}] Requesting Gemini for topic: ${randomTopic}...`);
      
      const prompt = `Write a comprehensive, engaging, and highly detailed SEO-friendly blog post (800 to 1200 words) for a construction company based in Jaipur about "${randomTopic}". 
        The blog post must be in-depth, covering multiple subtopics, professional advice, and deep industry insights.
        Return ONLY valid JSON with these EXACT keys:
        "title": (Catchy Title),
        "slug": (url-friendly-slug-with-random-id),
        "excerpt": (150 chars max summary),
        "content": (HTML string with <p> and <h2> tags for the body. Write at least 800 words. Do not use markdown backticks in the value.)
        Do NOT wrap the JSON in markdown code blocks. Return purely the JSON object.`;

      try {
        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-3.5-flash:generateContent?key=${key}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
        });

        if (!response.ok) {
          const status = response.status;
          if (status === 429 || status === 401 || status === 403 || status === 500) {
            logAi(`🛑 Fatal API Error ${status}. Stopping autopilot.`);
            logAi(status === 429 ? '⏳ Rate limit hit. Wait a few minutes and try again.' : `❌ Error ${status} — check your API key and try again.`);
            showToast(`Stopped: API Error ${status}`, 'error');
            break;
          }
          throw new Error('API Error: ' + status);
        }
        
        const data = await response.json();
        let textResult = data.candidates[0].content.parts[0].text.trim();
        // Strip markdown code fences if present
        textResult = textResult.replace(/^```json\s*/i, '').replace(/```\s*$/i, '').trim();
        const generated = JSON.parse(textResult);
        
        const newPost = {
          title: generated.title,
          slug: generated.slug + '-' + Math.floor(Math.random() * 10000),
          excerpt: generated.excerpt,
          content: generated.content,
          cat: 'Construction Insights',
          emoji: randomEmoji,
          publishDate: publishDate.toISOString(),
          readTime: '4 min read',
          author: 'Admin',
          status: 'scheduled',
          image: `https://image.pollinations.ai/prompt/${encodeURIComponent(generated.title + ', highly detailed architectural photography, construction site, 8k resolution')}?width=800&height=450&nologo=true`
        };

        await fetch('/api/blogs', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(newPost)
        });
        localBlogs.push(newPost);
        
        logAi(`✅ Created post: ${newPost.title} (Scheduled for ${publishDate.toDateString()})`);
        
        const pct = Math.floor((i / totalPosts) * 100);
        aiProgressBar.style.width = pct + '%';
        aiProgressText.textContent = `${i} / ${totalPosts}`;
        
        await new Promise(resolve => setTimeout(resolve, 3000));
        
      } catch (err) {
        logAi(`❌ Failed post ${i}: ${err.message}`);
        consecutiveFailures++;
        if (consecutiveFailures >= 3) {
          logAi(`🛑 3 consecutive failures. Stopping autopilot to avoid wasting API quota.`);
          showToast('Stopped after 3 consecutive failures.', 'error');
          break;
        }
        await new Promise(resolve => setTimeout(resolve, 5000));
        continue;
      }
      consecutiveFailures = 0; // Reset on success
    }
    
    logAi(`🎉 Finished! Generated ${localBlogs.length} posts total.`);
    showToast('AI Generation Complete!');
    aiStartBtn.disabled = false;
  });

